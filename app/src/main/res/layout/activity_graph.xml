<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="#7E7B79"
    android:layout_height="match_parent"
    tools:context=".menu.Graph">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent" >
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="persentase grafik"
                android:textStyle="bold"
                android:background="@color/birulangit"
                android:textAlignment="center"
                android:padding="10dp"
                android:textSize="20sp"/>

            <ImageView
                android:id="@+id/exitIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/baseline_chevron_left_24"
                android:layout_alignParentStart="true"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"/>

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/h_chart"
                android:layout_width="407dp"
                android:layout_height="173dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="50dp"
                android:layout_marginEnd="5dp"
                android:layout_marginBottom="5dp" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/v_chartbar"
                android:layout_below="@id/h_chart"
                android:layout_width="407dp"
                android:layout_height="173dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="50dp"
                android:layout_marginEnd="5dp"
                android:layout_marginBottom="5dp" />
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pie_chart"
                android:layout_below="@id/v_chartbar"
                android:layout_width="1000dp"
                android:layout_height="500dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="5dp"/>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>